@[grind .]
theorem Array.getElem!_push [Inhabited α] (i : Nat) (val : α) (arr : Array α) :
  i <= arr.size → (arr.push val)[i]! = if i < arr.size then arr[i]! else val := by
  intro; grind [Array.extract_succ_right]

-- attribute [-grind] getElem?_neg getElem?_pos getElem!_neg getElem!_pos Array.set!_eq_setIfInBounds
attribute [-grind] getElem?_neg getElem?_pos getElem!_neg getElem!_pos
-- attribute [-grind] Array.setIfInBounds_def Array.set!_eq_setIfInBounds

#check Array.getElem?_set

@[simp, grind .] theorem size_set! {xs : Array α} {i : Nat} {v : α} :
    (xs.set! i v).size = xs.size :=
  sorry

@[grind .] theorem getElem!_set! [Inhabited α] {xs : Array α} {i : Nat} (h : i < xs.size) {v : α} {j : Nat} :
    j < xs.size →
    i < xs.size →
    (xs.set! i v)[j]! = if i ≠ j then xs[j]! else if i = j then v else default:= by
  split <;> simp_all

